# LLM Configuration
# 选择默认 LLM provider: openai / spark / ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 讯飞星火（原生 WebSocket API，WSS 协议）
# 控制台：https://console.xfyun.cn/
# SPARK_MODEL 填写 domain 参数值，可选：
#   4.0Ultra   -> Spark 4.0 Ultra（推荐，最强推理）
#   max-32k    -> Spark Max-32K  （32K 长上下文）
#   generalv3.5-> Spark Max      （通用增强）
#   pro-128k   -> Spark Pro-128K （128K 超长上下文）
#   generalv3  -> Spark Pro      （专业版）
#   lite       -> Spark Lite     （轻量极速）
#   kjwx       -> 科技文献大模型  （论文/学术写作专项）
SPARK_APP_ID=your-app-id
SPARK_API_KEY=your-api-key
SPARK_API_SECRET=your-api-secret
SPARK_MODEL=4.0Ultra

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your-api-key-here
QDRANT_COLLECTION=knowledge_base
QDRANT_HTTPS=false

# 知识库文件存储
KB_STORAGE_PATH=data/kb_files

# 讯飞 TTS 语音合成
SPARK_TTS_APP_ID=your-app-id
SPARK_TTS_API_KEY=your-api-key
SPARK_TTS_API_SECRET=your-api-secret
SPARK_TTS_VOICE=xiaoyan
