# LLM Configuration
# 选择默认 LLM provider: openai / spark / ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 讯飞星火
SPARK_APP_ID=your-app-id
SPARK_API_KEY=your-api-key
SPARK_API_SECRET=your-api-secret
SPARK_MODEL=generalv3.5
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your-api-key-here
QDRANT_COLLECTION=knowledge_base
QDRANT_HTTPS=false

# 知识库文件存储
KB_STORAGE_PATH=data/kb_files

# 讯飞 TTS 语音合成
SPARK_TTS_APP_ID=your-app-id
SPARK_TTS_API_KEY=your-api-key
SPARK_TTS_API_SECRET=your-api-secret
SPARK_TTS_VOICE=xiaoyan
